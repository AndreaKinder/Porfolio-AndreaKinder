<h2>Contact</h2>
<form action="" method="post" id="Form">
    <label for="name">Nombre:</label>
    <input id="name" type="text" name="name" required>
    <label for="email">Email:</label>
    <input id="email" type="email" name="email" value="" required>
    <label for="reason">Reason:</label>
    <input id="reason" type="text" name="reason">
    <label for="message">Message:</label>
    <textarea name="message" id="message" rows="4"></textarea>
    <input type="submit" id="submit" value="Submit">
</form>

<style>
    form{
        display: flex;
        flex-direction: column;
    }
    label{
        border-radius: 20%;
    }
    #submit{
        margin-top: 1rem;
        background-color: #E95420;
        border-radius: 10px;
    }
</style>
<script>

// Validation formulario
function validarFormulario() {
    const nameInput = document.getElementById("name");
    const nameValue = nameInput?.ariaValueText;
    const emailInput = document.getElementById("email");
    const emailValue = emailInput?.ariaValueText;
    const reasonInput = document.getElementById("reason");
    const reasonValue = reasonInput?.ariaValueText;
    if ( nameValue || emailValue || reasonValue === null) {
        alert('[ERROR] All fields must have a value.');
        return false;
    }
    return true;
};
validarFormulario()

</script>    
    